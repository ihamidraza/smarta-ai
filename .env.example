# Copy this file to `.env` and adjust as needed.
#
# The agent works with any OpenAI-compatible backend. Pick one with LLM_PROVIDER:
#   ollama   (default) — local models, no API key. Run `ollama serve` first.
#   deepseek           — https://platform.deepseek.com/
#   openai             — https://platform.openai.com/
# Add your own in chatbot/providers.py.

LLM_PROVIDER=ollama

# Model to use. Defaults to the provider's default if unset.
#   ollama:   llama3.2:3b   (run `ollama pull llama3.2:3b`)
#   deepseek: deepseek-chat
#   openai:   gpt-4o-mini
LLM_MODEL=llama3.2:3b

# API key. Not needed for local providers like Ollama. Required for hosted ones.
# LLM_API_KEY=sk-your-key-here

# Optional overrides (defaults come from the selected provider)
# LLM_BASE_URL=http://localhost:11434/v1
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
# LLM_TIMEOUT=60

# Context budget (estimated input tokens). When the conversation exceeds this,
# the oldest turns are summarized into a running summary instead of dropped.
# LLM_MAX_CONTEXT_TOKENS=6000
